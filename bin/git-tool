#!/bin/bash
BASE_DIR=$(dirname "$(dirname "$(readlink -f "$0")")")
source "$BASE_DIR/lib/utils.sh"

# ==========================================
# CONFIGURACIÓN PERSISTENTE
# ==========================================

CONFIG_DIR="$HOME/.config/admin-cli"
CONFIG_FILE="$CONFIG_DIR/projects.conf"

init_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        mkdir -p "$CONFIG_DIR"
        cat > "$CONFIG_FILE" << 'EOF'
# Directorios donde buscar proyectos (uno por línea)
# Usa [d] > [a] en el Gestor de Proyectos para agregar rutas
EOF
    fi
}

load_search_roots() {
    SEARCH_ROOTS=()
    while IFS= read -r line; do
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
        expanded=$(eval echo "$line")
        SEARCH_ROOTS+=("$expanded")
    done < "$CONFIG_FILE"
}

# ==========================================
# NAVEGADOR DE CARPETAS
# ==========================================

browse_directory() {
    local current="$HOME"

    while true; do
        clear
        echo -e "${BLUE}${BOLD}==================================================${NC}"
        echo -e "           ${CYAN}${BOLD}NAVEGADOR DE CARPETAS${NC}"
        echo -e "${BLUE}${BOLD}==================================================${NC}"
        echo -e ""
        echo -e "${BOLD}Ubicación:${NC} ${CYAN}$current${NC}"
        echo -e "${BLUE}--------------------------------------------------${NC}"

        # Listar subdirectorios
        local dirs=()
        while IFS= read -r d; do
            dirs+=("$d")
        done < <(find "$current" -maxdepth 1 -mindepth 1 -type d ! -name '.*' 2>/dev/null | sort)

        if [ ${#dirs[@]} -eq 0 ]; then
            echo -e "  ${YELLOW}(sin subcarpetas)${NC}"
        else
            local i=1
            for d in "${dirs[@]}"; do
                local name=$(basename "$d")
                local marker=""
                # Marcar si tiene repos git dentro
                if [ -d "$d/.git" ]; then
                    marker=" ${GREEN}(repo git)${NC}"
                fi
                echo -e "  ${CYAN}[${i}]${NC} 📁 ${BOLD}${name}${NC}${marker}"
                ((i++))
            done
        fi

        echo -e "${BLUE}--------------------------------------------------${NC}"
        echo -e "  ${GREEN}[Enter]${NC}  ${BOLD}SELECCIONAR${NC} esta carpeta como raíz de proyectos"
        echo -e "  [${BOLD}..${NC}]     Subir un nivel"
        echo -e "  [${BOLD}.${NC}]      Mostrar carpetas ocultas"
        echo -e "  [${BOLD}/${NC}]      Escribir ruta manualmente"
        echo -e "  [${BOLD}q${NC}]      Cancelar"
        echo -e ""
        echo -ne "${BOLD}Navegar > ${NC}"
        read -r NAV

        # Seleccionar directorio actual
        if [ -z "$NAV" ]; then
            echo "$current"
            return 0
        fi

        # Cancelar
        if [[ "$NAV" == "q" || "$NAV" == "Q" ]]; then
            return 1
        fi

        # Subir nivel
        if [[ "$NAV" == ".." ]]; then
            local parent=$(dirname "$current")
            if [ "$parent" != "$current" ]; then
                current="$parent"
            fi
            continue
        fi

        # Mostrar ocultas
        if [[ "$NAV" == "." ]]; then
            clear
            echo -e "${BLUE}${BOLD}==================================================${NC}"
            echo -e "        ${CYAN}${BOLD}CARPETAS OCULTAS EN:${NC} $current"
            echo -e "${BLUE}${BOLD}==================================================${NC}"

            local hidden=()
            while IFS= read -r d; do
                hidden+=("$d")
            done < <(find "$current" -maxdepth 1 -mindepth 1 -type d -name '.*' 2>/dev/null | sort)

            if [ ${#hidden[@]} -eq 0 ]; then
                echo -e "  ${YELLOW}(sin carpetas ocultas)${NC}"
            else
                local j=1
                for d in "${hidden[@]}"; do
                    echo -e "  ${CYAN}[${j}]${NC} 📁 ${BOLD}$(basename "$d")${NC}"
                    ((j++))
                done
            fi

            echo -e ""
            echo -ne "${BOLD}Número para entrar (Enter para volver) > ${NC}"
            read -r HSEL
            if [[ "$HSEL" =~ ^[0-9]+$ ]] && [ "$HSEL" -ge 1 ] && [ "$HSEL" -le "${#hidden[@]}" ]; then
                current="${hidden[$((HSEL-1))]}"
            fi
            continue
        fi

        # Ruta manual
        if [[ "$NAV" == "/" ]]; then
            echo -ne "${BOLD}Escribe la ruta: ${NC}"
            read -e -r MANUAL_PATH
            MANUAL_PATH=$(eval echo "$MANUAL_PATH")
            if [ -d "$MANUAL_PATH" ]; then
                current="$MANUAL_PATH"
            else
                echo -e "${RED}No existe: $MANUAL_PATH${NC}"
                sleep 1
            fi
            continue
        fi

        # Navegar por número
        if [[ "$NAV" =~ ^[0-9]+$ ]] && [ "$NAV" -ge 1 ] && [ "$NAV" -le "${#dirs[@]}" ]; then
            current="${dirs[$((NAV-1))]}"
            continue
        fi

        echo -e "${RED}Opción no válida.${NC}"
        sleep 0.5
    done
}

# ==========================================
# GESTIÓN DE DIRECTORIOS
# ==========================================

manage_directories() {
    while true; do
        clear
        echo -e "${BLUE}${BOLD}==================================================${NC}"
        echo -e "           ${YELLOW}${BOLD}DIRECTORIOS DE PROYECTOS${NC}"
        echo -e "${BLUE}${BOLD}==================================================${NC}"
        echo -e ""

        local dirs=()
        while IFS= read -r line; do
            [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
            local expanded=$(eval echo "$line")
            dirs+=("$expanded")
        done < "$CONFIG_FILE"

        if [ ${#dirs[@]} -eq 0 ]; then
            echo -e "  ${YELLOW}No hay directorios configurados.${NC}"
            echo -e "  ${YELLOW}Agrega uno para empezar a escanear proyectos.${NC}"
        else
            echo -e "${BOLD}Directorios configurados:${NC}"
            echo -e "${BLUE}--------------------------------------------------${NC}"
            local i=1
            for d in "${dirs[@]}"; do
                if [ -d "$d" ]; then
                    local count=$(find "$d" -maxdepth 3 -name ".git" -type d 2>/dev/null | wc -l)
                    echo -e "  ${GREEN}[${i}]${NC} ${BOLD}$d${NC}"
                    echo -e "       ${CYAN}$count repos encontrados${NC}"
                else
                    echo -e "  ${RED}[${i}]${NC} ${BOLD}$d${NC}"
                    echo -e "       ${RED}(no existe)${NC}"
                fi
                ((i++))
            done
        fi

        echo -e "${BLUE}--------------------------------------------------${NC}"
        echo -e "  [${BOLD}a${NC}] ${GREEN}Agregar${NC} directorio (Navegador)"
        echo -e "  [${BOLD}Número${NC}] ${RED}Eliminar${NC} directorio"
        echo -e "  [${BOLD}e${NC}] ${YELLOW}Editar${NC} config manualmente"
        echo -e "  [${BOLD}q${NC}] Volver"
        echo -e ""
        echo -ne "${BOLD}Opción > ${NC}"
        read -r OPT

        case $OPT in
            a)
                SELECTED=$(browse_directory)
                if [ $? -eq 0 ] && [ -n "$SELECTED" ]; then
                    if grep -qF "$SELECTED" "$CONFIG_FILE" 2>/dev/null; then
                        echo -e "${YELLOW}Esa ruta ya está configurada.${NC}"
                        sleep 1
                    else
                        echo "$SELECTED" >> "$CONFIG_FILE"
                        load_search_roots
                        echo -e "${GREEN}Agregado: $SELECTED${NC}"
                        sleep 1
                    fi
                fi
                ;;

            e)
                ${EDITOR:-nano} "$CONFIG_FILE"
                load_search_roots
                ;;

            q|Q)
                load_search_roots
                REPOS=()
                return
                ;;

            *)
                if [[ "$OPT" =~ ^[0-9]+$ ]] && [ "$OPT" -ge 1 ] && [ "$OPT" -le "${#dirs[@]}" ]; then
                    local to_remove="${dirs[$((OPT-1))]}"
                    echo -ne "${RED}¿Eliminar '$to_remove'? [s/N]: ${NC}"
                    read -r CONFIRM
                    if [[ "$CONFIRM" =~ ^[sS]$ ]]; then
                        local escaped=$(printf '%s\n' "$to_remove" | sed 's/[[\.*^$()+?{|]/\\&/g')
                        grep -v "^${escaped}$" "$CONFIG_FILE" > "${CONFIG_FILE}.tmp"
                        mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
                        load_search_roots
                        echo -e "${GREEN}Eliminado.${NC}"
                    fi
                    sleep 1
                fi
                ;;
        esac
    done
}

# ==========================================
# ESCANEO DE REPOS
# ==========================================

STAT_DIRTY="${RED}📦 MODIFICADO${NC}"
STAT_CLEAN="${GREEN}✨ LIMPIO${NC}"
STAT_UNTRACKED="${YELLOW}❓ UNTRACKED${NC}"

scan_repos() {
    REPOS=()
    echo -e "${BLUE}Escaneando repositorios...${NC}"
    for root in "${SEARCH_ROOTS[@]}"; do
        if [ -d "$root" ]; then
            while IFS= read -r gitdir; do
                repo_root=$(dirname "$gitdir")
                REPOS+=("$repo_root")
            done < <(find "$root" -maxdepth 3 -name ".git" -type d 2>/dev/null)
        fi
    done
}

# ==========================================
# INICIALIZACIÓN
# ==========================================

init_config
load_search_roots

# Si no hay rutas configuradas, ir directo a gestión
if [ ${#SEARCH_ROOTS[@]} -eq 0 ]; then
    clear
    echo -e "${YELLOW}${BOLD}Primera vez: necesitas agregar al menos un directorio de proyectos.${NC}"
    echo -e ""
    sleep 1
    manage_directories
fi

# ==========================================
# PANTALLA PRINCIPAL
# ==========================================

while true; do
    clear
    echo -e "${BLUE}${BOLD}==================================================${NC}"
    echo -e "           ${MAGENTA}${BOLD}GESTOR DE PROYECTOS${NC}"
    echo -e "${BLUE}${BOLD}==================================================${NC}"

    if [ ${#REPOS[@]} -eq 0 ]; then
        scan_repos
    fi

    if [ ${#REPOS[@]} -eq 0 ]; then
        echo -e "\n${YELLOW}No se encontraron repositorios.${NC}"
        echo -e "Usa ${BOLD}[d]${NC} para configurar directorios.\n"
    else
        echo -e "${BOLD}Repositorios:${NC} ${#REPOS[@]}  (${CYAN}${#SEARCH_ROOTS[@]} directorios${NC})"
        printf "${BOLD}%-4s %-35s %-15s${NC}\n" "ID" "PROYECTO" "ESTADO"
        echo -e "${BLUE}--------------------------------------------------${NC}"

        i=0
        for repo in "${REPOS[@]}"; do
            NAME=$(basename "$repo")
            cd "$repo"
            if [ -n "$(git status --porcelain)" ]; then
                if [ -n "$(git status --porcelain | grep '^??')" ]; then
                    STATUS="$STAT_UNTRACKED"
                else
                    STATUS="$STAT_DIRTY"
                fi
            else
                STATUS="$STAT_CLEAN"
            fi
            printf "${CYAN}[%d]${NC}  %-35s %b\n" "$i" "${NAME:0:34}" "$STATUS"
            ((i++))
        done
    fi

    echo -e "${BLUE}==================================================${NC}"
    echo -e "  [${BOLD}p${NC}] ⬇️  ${BOLD}PULL ALL${NC} (Actualizar todos)"
    echo -e "  [${BOLD}s${NC}] 🔄 ${BOLD}Re-escanear${NC}"
    echo -e "  [${BOLD}d${NC}] 📁 ${BOLD}Directorios${NC} (Configurar rutas)"
    echo -e "  [${BOLD}Número${NC}] Abrir terminal en el proyecto"
    echo -e "  [${BOLD}q${NC}] Salir"
    echo -e ""
    echo -ne "${BOLD}Opción > ${NC}"
    read -r OPT

    if [[ "$OPT" == "q" || "$OPT" == "Q" ]]; then exit 0; fi

    if [[ "$OPT" == "s" ]]; then
        REPOS=()
        continue
    fi

    if [[ "$OPT" == "d" || "$OPT" == "D" ]]; then
        manage_directories
        continue
    fi

    if [[ "$OPT" == "p" ]]; then
        echo -e "\n${YELLOW}Actualizando todos...${NC}"
        for repo in "${REPOS[@]}"; do
            echo -ne "$(basename "$repo")... "
            cd "$repo"
            git pull &>/dev/null
            if [ $? -eq 0 ]; then echo -e "${GREEN}OK${NC}"; else echo -e "${RED}Error${NC}"; fi
        done
        pause
        continue
    fi

    if [[ "$OPT" =~ ^[0-9]+$ ]] && [ "$OPT" -lt "${#REPOS[@]}" ]; then
        TARGET="${REPOS[$OPT]}"
        clear
        echo -e "${GREEN}Entrando a: $TARGET${NC}"
        echo -e "(Escribe 'exit' para volver)"
        cd "$TARGET"
        $SHELL
        continue
    fi
done
